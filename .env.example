NODE_ENV=production
PORT=3333
APP_BASE_URL=https://montadores.suaempresa.com.br

# Oracle/WinThor
ORACLE_USER=U_CC4UJM_WI
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=
ORACLE_SCHEMA=U_CC4UJM_WI
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=10
ORACLE_POOL_INCREMENT=1
ORACLE_POOL_ALIAS=montadoresPool
ORACLE_STMT_CACHE_SIZE=30

# Segurança — OBRIGATÓRIO alterar em produção (mínimo 32 chars aleatórios)
JWT_SECRET=TROQUE_POR_UMA_STRING_ALEATORIA_LONGA_AQUI
JWT_EXPIRES_HOURS=8
PUBLIC_TOKEN_TTL_HOURS=168

# CORS — URLs permitidas separadas por vírgula (OBRIGATÓRIO em produção)
CORS_ORIGINS=https://montadores.suaempresa.com.br

# Usuário admin inicial (criado automaticamente pelo seed se não existir)
ADMIN_EMAIL=admin@suaempresa.com.br
ADMIN_PASSWORD=TROQUE_POR_SENHA_SEGURA

# ── Feature flags ────────────────────────────────────────────────────────────
# Ative somente em homologação antes de produção. false = desabilitado.
ENABLE_DEPARTMENT_COMMISSION_RULES=false
ENABLE_GEO_MATCHING=false
ENABLE_PIX_PAYMENTS=false
ENABLE_PWA_OFFLINE=true
ENABLE_REWORK_SCORE_IMPACT=false
ENABLE_STRICT_RBAC=true
# Notificações reais do montador — false = DRY_RUN apenas (seguro para homologação)
ENABLE_PROVIDER_WHATSAPP_NOTIFICATIONS=false
ENABLE_PROVIDER_PUSH_NOTIFICATIONS=false
# Provider WhatsApp (somente quando ENABLE_PROVIDER_WHATSAPP_NOTIFICATIONS=true)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Identidade visual (white-label portal do cliente)
COMPANY_NAME=Rodrigues Colchões
LOGO_URL=/logo-rodrigues.svg
PRIMARY_COLOR=#1F2855
SUPPORT_PHONE=(00) 00000-0000
