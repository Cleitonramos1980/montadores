# ── PRODUÇÃO — LEIA ANTES DO GO-LIVE ─────────────────────────────────────────
# Defina NODE_ENV=production no ambiente REAL. SEM isto o servidor roda em modo DEV:
# as travas fatais de segurança do config.ts ficam INERTES e o JWT cai num segredo de
# desenvolvimento commitado. Com NODE_ENV=production o boot ABORTA se faltar JWT_SECRET
# forte (>=32), CORS_ORIGINS ou ADMIN_PASSWORD — por isso defina os três ANTES de subir.
NODE_ENV=production

PORT=3333
APP_BASE_URL=http://localhost:5173

# Oracle/WinThor — use os mesmos valores do ambiente Lara
ORACLE_USER=U_CC4UJM_WI
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=
ORACLE_SCHEMA=U_CC4UJM_WI
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=5
ORACLE_POOL_INCREMENT=1
ORACLE_POOL_ALIAS=montadoresPool
ORACLE_STMT_CACHE_SIZE=30

# Segurança — OBRIGATÓRIO definir em produção (mín. 32 caracteres, gere um valor forte)
JWT_SECRET=
JWT_EXPIRES_HOURS=8
PUBLIC_TOKEN_TTL_HOURS=168

# Pepper dedicado ao hash legado (opcional; fallback para JWT_SECRET se vazio)
PASSWORD_PEPPER=

# CORS — URLs permitidas separadas por vírgula (omitir para permitir todas — apenas dev)
# CORS_ORIGINS=https://app.laranexus.com.br,https://montadores.lara.com.br

# Usuário admin inicial (seed) — sem estes dois valores nenhum admin é criado
ADMIN_EMAIL=
ADMIN_PASSWORD=
