{
  "name": "app-montadores",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "start": "tsx src/server/index.ts",
    "migrate": "tsx src/server/db/migrate.ts",
    "seed": "tsx src/server/db/seed.ts",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/api.integration.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "lucide-react": "^0.542.0",
    "oracledb": "^6.9.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.20.5",
    "uuid": "^11.1.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/pino": "^7.0.4",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^10.0.3",
    "supertest": "^7.2.2",
    "typescript": "^5.9.2",
    "vite": "^8.1.2",
    "vitest": "^3.2.4"
  }
}
